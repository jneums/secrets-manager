{
  "name": "secrets-manager",
  "version": "0.1.0",
  "description": "A Motoko MCP server generated by create-motoko-mcp-server for the Prometheus Protocol.",
  "scripts": {
    "start": "dfx start --background",
    "stop": "dfx stop",
    "deploy": "dfx deploy",
    "deploy:ic": "dfx deploy --network ic",
    "mops:install": "mops install",
    "inspector": "npx @modelcontextprotocol/inspector",
    "test": "vitest run",
    "test:watch": "vitest",
    "app-store": "npx @prometheus-protocol/app-store-cli",
    "auth": "npx @prometheus-protocol/auth-cli"
  },
  "devDependencies": {
    "@dfinity/pic": "^0.16.1",
    "@icp-sdk/core": "^4.2.2",
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "motoko",
    "mcp",
    "prometheus-protocol",
    "dfinity",
    "internet-computer"
  ],
  "author": "",
  "license": "MIT"
}